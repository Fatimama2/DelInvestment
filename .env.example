# ----------------------------------------------------------------------------
# PSX Trading Prototype — environment configuration
# Copy this file to ".env" (which is git-ignored) and fill in your values.
# The app RUNS WITHOUT any key: all market data, portfolio, trading and
# flashcards work from seeded MOCK data. Only the *live* AI chat needs a key.
# ----------------------------------------------------------------------------

# Anthropic API key for the in-app AI assistant.
# Get one at https://console.anthropic.com/  (leave blank to use the offline
# assistant fallback — flashcards + canned help still work without it).
ANTHROPIC_API_KEY=

# Claude model used by the assistant (current default; see /docs).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Backend HTTP port.
PORT=4000

# Web dev-server origin allowed by CORS.
WEB_ORIGIN=http://localhost:5173
